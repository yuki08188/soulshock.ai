---
---
<header class="header">
  <nav class="container header__nav">
    <a href="/" class="header__logo">
      <span class="header__logo-text">震魂<span class="gold-text">科技</span></span>
    </a>
    <div class="header__links">
      <a href="/courses" class="header__link">课程</a>
      <a href="/apps" class="header__link">应用</a>
      <a href="/about" class="header__link">关于</a>
      <a href="/join" class="header__link header__link--cta">加入我们</a>
    </div>
  </nav>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(10, 10, 10, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .header__nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  .header__logo {
    text-decoration: none;
  }

  .header__logo-text {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .header__links {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .header__link {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .header__link:hover {
    color: var(--color-text);
  }

  .header__link--cta {
    color: var(--color-gold);
    font-weight: 600;
  }

  .header__link--cta:hover {
    color: var(--color-gold-light);
  }

  @media (max-width: 768px) {
    .header__links {
      gap: var(--space-md);
    }
    .header__link {
      font-size: 0.8rem;
    }
  }
</style>
