      <div class="flex-1">
        <h3 class="text-xl font-bold tracking-tight text-neutral-100 mb-2">震魂<span class="text-amber-400/90">科技</span></h3>
        <p class="text-sm text-neutral-500">原生为核，震魂为翼</p>
      </div>
      <div class="flex flex-wrap gap-12">
        <div class="flex flex-col gap-3 min-w-[100px]">
          <h4 class="text-[11px] font-semibold tracking-widest uppercase text-neutral-600">产品</h4>
          <a href="/courses" class="text-sm text-neutral-500 hover:text-neutral-300 transition-colors duration-300 no-underline">课程</a>
          <a href="/apps" class="text-sm text-neutral-500 hover:text-neutral-300 transition-colors duration-300 no-underline">应用商城</a>
          <a href="/services" class="text-sm text-neutral-500 hover:text-neutral-300 transition-colors duration-300 no-underline">服务</a>
