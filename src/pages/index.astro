---
import BaseLayout from '../layouts/BaseLayout.astro';

const apps = [
  {
    category: '效率工具',
    icon: '💡',
    name: '意识流涌现笔记',
    subtitle: 'FlowMind',
    desc: '捕捉大脑最初始的混乱想法，AI 不改动核心意志，仅梳理脉络，放大原生灵感。',
  },
  {
    category: '教育辅助',
    icon: '💡',
    name: '原生天赋反思镜',
    subtitle: 'AuraMirror',
    desc: '通过苏格拉底式追问，提取你过往高光时刻，揭示你本就拥有的核心优势。',
  },
  {
    category: '内容创作',
    icon: '💡',
    name: '灵魂共振文案师',
    subtitle: 'SoulEcho',
    desc: '输入你的真心话，AI 用现代文学与科技感的语言，帮你放大文字中的情绪张力。',
  },
  {
    category: '行业专用',
    icon: '💡',
    name: '独创商业逻辑解构器',
    subtitle: 'BizRevealer',
    desc: '输入业务碎片，自动推演并揭示专属于你的、不可复制的商业护城河。',
  },
  {
    category: '生活服务',
    icon: '💡',
    name: '精神内耗对冲舱',
    subtitle: 'ZenAgent',
    desc: '用纯粹的理性逻辑与数字哲学，帮你拆解情绪迷雾，还原最本真的内在秩序。',
  },
];

const tabs = ['全部', '效率工具', '教育辅助', '内容创作', '行业专用', '生活服务'];
---

<BaseLayout>
  <!-- ═══ Hero 巨幕区 ═══ -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden px-6">
    <!-- 暗金色渐变光晕背景 -->
    <div class="absolute inset-0 bg-[#0a0a0a] pointer-events-none" />
    <div class="absolute top-[-30%] left-1/2 -translate-x-1/2 w-[800px] h-[800px] rounded-full bg-gradient-to-br from-amber-500/5 via-amber-400/3 to-transparent blur-[120px] pointer-events-none" />

    <div class="relative z-10 text-center max-w-4xl mx-auto">
      <!-- 主 Slogan：流光渐变 -->
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-extrabold tracking-tighter leading-[1.05] mb-8">
        <span class="bg-gradient-to-r from-neutral-100 via-amber-200 to-yellow-500 bg-clip-text text-transparent">
          原生为核，<br />震魂为翼。
        </span>
      </h1>

      <!-- 副标题 -->
      <p class="text-lg md:text-xl text-neutral-400/90 max-w-2xl mx-auto mb-12 leading-relaxed tracking-tight">
        你本来就有价值。<br />
        震魂用 AI 之光，为你添翼。
      </p>

      <!-- CTA 按钮组 -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6">
        <a
          href="/courses"
          class="group relative inline-flex items-center gap-2 px-8 py-3.5 rounded-xl text-sm font-semibold
                 bg-black text-amber-400/90 border border-amber-500/20
                 transition-all duration-500 ease-out
                 hover:border-amber-400/50 hover:text-amber-300
                 hover:shadow-[0_0_30px_-5px_rgba(251,191,36,0.25)]
                 active:scale-[0.98]"
        >
          <span>浏览课程</span>
          <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a
          href="/apps"
          class="text-sm text-neutral-500 hover:text-neutral-300 transition-colors duration-300 underline underline-offset-4 decoration-neutral-800 hover:decoration-amber-500/30"
        >
          逛应用商城 →
        </a>
      </div>
    </div>

    <!-- 底部微光装饰线 -->
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-1/2 h-px bg-gradient-to-r from-transparent via-amber-500/15 to-transparent" />
  </section>

  <!-- ═══ 分类标签栏 ═══ -->
  <section class="px-6 py-8 md:py-12">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-wrap items-center gap-2 md:gap-3 pb-6 border-b border-neutral-800/60">
        {
          tabs.map((tab) => (
            <button
              class="tab-btn px-4 py-2 rounded-lg text-sm font-medium transition-all duration-300
                     text-neutral-500 hover:text-neutral-300
                     data-active:text-amber-400/90 data-active:bg-amber-400/5 data-active:shadow-[inset_0_1px_0_rgba(251,191,36,0.08)]"
              data-active={tab === '全部' ? '' : undefined}
            >
              {tab}
            </button>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══ 应用卡片网格 ═══ -->
  <section class="px-6 pb-32">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-3 gap-5">
        {
          apps.map((app) => (
            <article
              class="group relative
                     bg-neutral-900/30 backdrop-blur-sm
                     border border-neutral-800/50
                     rounded-2xl p-6 md:p-7
                     transition-all duration-500 ease-out
                     hover:-translate-y-1.5
                     hover:border-amber-500/25
                     hover:bg-neutral-900/50
                     hover:shadow-[0_8px_40px_-12px_rgba(0,0,0,0.6)]"
            >
              <!-- 卡片背景微光 -->
              <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-amber-500/[0.02] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none" />

              <div class="relative z-10 flex flex-col gap-4">
                <!-- 分类标签 -->
                <span class="inline-block self-start text-[11px] font-medium tracking-widest uppercase text-neutral-600 group-hover:text-amber-400/60 transition-colors duration-500">
                  {app.category}
                </span>

                <!-- 图标 -->
                <div class="text-3xl md:text-4xl transition-all duration-500 group-hover:scale-110 group-hover:drop-shadow-[0_0_12px_rgba(251,191,36,0.3)]">
                  {app.icon}
                </div>

                <!-- 名称 + 副标题 -->
                <div>
                  <h3 class="text-lg font-semibold text-neutral-100 tracking-tight mb-0.5">
                    {app.name}
                  </h3>
                  <p class="text-sm text-neutral-500 font-mono tracking-tight">
                    {app.subtitle}
                  </p>
                </div>

                <!-- 描述 -->
                <p class="text-sm text-neutral-400/80 leading-relaxed tracking-tight group-hover:text-neutral-300/90 transition-colors duration-500">
                  {app.desc}
                </p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══ FOUC Guard ═══ -->
  <style>
    /* 保证 JS 加载前标签也有样式 */
    .tab-btn {
      cursor: default;
    }
    .tab-btn[data-active] {
      color: rgba(251, 191, 36, 0.9);
      background: rgba(251, 191, 36, 0.05);
      box-shadow: inset 0 1px 0 rgba(251, 191, 36, 0.08);
    }
    article {
      cursor: default;
    }
  </style>
</BaseLayout>
